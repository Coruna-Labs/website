---
/* ============================================================
   PROJECT CARD
   Renders one project. If the project has a URL (the tool is
   live or in preview), the whole card links out to it.
   ============================================================ */
import { useTranslations } from '../i18n/ui.js';
const { title, description, status = 'idea', url, source, lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const statusLabel = {
  live: t('project.status.live'),
  soon: t('project.status.soon'),
  idea: t('project.status.idea'),
};

const Tag = url ? 'a' : 'div';
const tagProps = url ? { href: url, target: '_blank', rel: 'noopener' } : {};
---
<Tag class="card" {...tagProps}>
  <span class={`pill ${status}`}>{statusLabel[status]}</span>
  <h3 style="margin-top:14px;">{title}</h3>
  <p>{description}</p>
  {source && <div class="meta">Data · {source}</div>}
</Tag>
