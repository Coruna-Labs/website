---
/* ============================================================
   POST CARD
   Renders one blog post as a card linking to the full article.
   ============================================================ */
import { localizePath, useTranslations } from '../i18n/ui.js';
const { title, description, pubDate, slug, lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const dateStr = pubDate
  ? new Date(pubDate).toLocaleDateString(lang === 'gl' ? 'gl-ES' : lang, {
      year: 'numeric', month: 'short', day: 'numeric',
    })
  : '';
---
<a class="card" href={localizePath('/blog/' + slug, lang)}>
  <span class="kicker">{t('blog.title')}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="meta">{dateStr}</div>
</a>
