---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/ui.js';

const lang = 'gl';
const t = useTranslations(lang);

const projects = (await getCollection('projects', (p) => p.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);
---
<Base lang={lang} active="projects" title={`${t('projects.title')} · Coruña Labs`} description={t('projects.lede')}>
  <section class="section">
    <div class="wrap">
      <p class="section-label">{t('projects.title')}</p>
      <h1 style="margin-bottom:14px;">{t('projects.title')}</h1>
      <p class="muted prose" style="margin-bottom:36px;">{t('projects.lede')}</p>
      <div class="grid">
        {projects.map((p) => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            status={p.data.status}
            url={p.data.url}
            source={p.data.source}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>
</Base>
