---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { useTranslations, stripLangPrefix } from '../../../i18n/ui.js';

const lang = 'es';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.data.lang === 'es' && !p.data.draft);
  return posts.map((post) => ({
    params: { slug: stripLangPrefix(post.slug, 'es') },
    props: { post },
  }));
}

const t = useTranslations(lang);
const { post } = Astro.props;
const { Content } = await post.render();

const dateStr = new Date(post.data.pubDate).toLocaleDateString('es', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<Base lang={lang} active="blog" title={`${post.data.title} · Coruña Labs`} description={post.data.description}>
  <article class="article">
    <div class="wrap">
      <div class="article-head">
        <p class="kicker">{t('blog.title')}</p>
        <h1>{post.data.title}</h1>
        <p class="byline">{post.data.author} · {dateStr}</p>
      </div>
      <div class="article-body">
        <Content />
      </div>
    </div>
  </article>
</Base>
