---
import Base from '../../../layouts/Base.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, stripLangPrefix } from '../../../i18n/ui.js';

const lang = 'es';
const t = useTranslations(lang);

const posts = (await getCollection('blog', (p) => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base lang={lang} active="blog" title={`${t('blog.title')} · Coruña Labs`} description={t('blog.lede')}>
  <section class="section">
    <div class="wrap">
      <p class="section-label">{t('blog.title')}</p>
      <h1 style="margin-bottom:14px;">{t('blog.title')}</h1>
      <p class="muted prose" style="margin-bottom:36px;">{t('blog.lede')}</p>
      <div class="grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={stripLangPrefix(post.slug, lang)}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>
</Base>
