---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, localizePath } from '../../i18n/ui.js';

const lang = 'en';
const t = useTranslations(lang);

const projects = (await getCollection('projects', (p) => p.data.lang === lang))
  .sort((a, b) => a.data.order - b.data.order);

const posts = (await getCollection('blog', (p) => p.data.lang === lang && !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<Base lang={lang} active="" title="Coruña Labs" description={t('tagline')}>
  <section class="hero">
    <div class="wrap">
      <h1>{t('hero.title')}</h1>
      <p class="lede">{t('hero.lede')}</p>
      <div class="cta-row">
        <a class="btn" href={localizePath('/projects', lang)}>{t('hero.cta.projects')}</a>
        <a class="btn ghost" href={localizePath('/about', lang)}>{t('hero.cta.about')}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="section-label">{t('home.projects.label')}</p>
      <h2 style="margin-bottom:28px;">{t('home.projects.title')}</h2>
      <div class="grid">
        {projects.map((p) => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            status={p.data.status}
            url={p.data.url}
            source={p.data.source}
            lang={lang}
          />
        ))}
      </div>
      <p style="margin-top:24px;">
        <a href={localizePath('/projects', lang)}>{t('home.projects.all')} →</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="section-label">{t('home.blog.label')}</p>
      <h2 style="margin-bottom:28px;">{t('home.blog.title')}</h2>
      <div class="grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            slug={post.slug}
            lang={lang}
          />
        ))}
      </div>
      <p style="margin-top:24px;">
        <a href={localizePath('/blog', lang)}>{t('home.blog.all')} →</a>
      </p>
    </div>
  </section>
</Base>
